# Cherry in the Haystack — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to version control.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Connection URL for the PostgreSQL 16 + pgvector database.
# Local dev default matches docker-compose.yml service.
DATABASE_URL=postgresql://cherry:cherry_dev@localhost:5432/cherry_db

# ── Notion ───────────────────────────────────────────────────────────────────
# Notion Integration Token — create an integration at https://www.notion.so/my-integrations
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# API key for Claude models — obtain at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token (or GitHub App token) with contents:write scope.
# Used by the weekly-publish job to commit approved content to the repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Slack ────────────────────────────────────────────────────────────────────
# Incoming Webhook URL for posting pipeline alerts to a Slack channel.
# Create at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Twitter / X ──────────────────────────────────────────────────────────────
# Bearer Token for the Twitter v2 API (read-only, for source monitoring).
# Obtain at https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAA%2FXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Reddit ───────────────────────────────────────────────────────────────────
# OAuth2 credentials for the Reddit API (read-only app).
# Register an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Local Docker services (optional overrides) ───────────────────────────────
POSTGRES_USER=cherry
POSTGRES_PASSWORD=cherry_dev
POSTGRES_DB=cherry_db
